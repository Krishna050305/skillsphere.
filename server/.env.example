# SkillSphere Express Backend Environment Variables Example

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Connection (use mongodb://mongo:27017/skillsphere for docker-compose)
MONGODB_URI=mongodb://localhost:27017/skillsphere

# Authentication (JWT Secrets)
JWT_SECRET=your_jwt_secret_should_be_long_and_secure
JWT_EXPIRES_IN=7d

# Google OAuth Credentials (for authentication)
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# Cloudinary Credentials (for profile pictures and job attachment uploads)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Razorpay Credentials (for escrow payments)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMTP Server Configurations (for email verification and job alerts)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=noreply@skillsphere.com

# Machine Learning Service URL (use http://ml-service:8000 for docker-compose)
ML_SERVICE_URL=http://localhost:8000
