# SkillSphere ML Service Environment Variables Example

# Port to run uvicorn server on (defaults to 8000)
PORT=8000

# Name of the Hugging Face sentence-transformers model to download/load
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Force mock embedding model without downloading weights (useful for local builds / offline dev)
# Set to 'true' to use the fast mathematical random/seeded mock generator
USE_MOCK_ML=true
